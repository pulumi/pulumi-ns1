{
    "compilerOptions": {
        // Output
        "outDir": "bin",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "stripInternal": true,
        // Environment
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "moduleDetection": "force",
        "types": ["node"],
        // Type Checking
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "skipLibCheck": true
    },
    "files": [
        "accountWhitelist.ts",
        "alert.ts",
        "apikey.ts",
        "application.ts",
        "config/index.ts",
        "config/vars.ts",
        "dataFeed.ts",
        "dataSource.ts",
        "dataset.ts",
        "dnsview.ts",
        "getBillingUsage.ts",
        "getDNSSec.ts",
        "getMonitoringRegions.ts",
        "getNetworks.ts",
        "getRecord.ts",
        "getZone.ts",
        "index.ts",
        "monitoringJob.ts",
        "notifyList.ts",
        "provider.ts",
        "pulsarJob.ts",
        "record.ts",
        "redirect.ts",
        "redirectCertificate.ts",
        "team.ts",
        "tsigkey.ts",
        "types/index.ts",
        "types/input.ts",
        "types/output.ts",
        "user.ts",
        "utilities.ts",
        "zone.ts"
    ]
}
